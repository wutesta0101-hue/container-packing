# ============================================================
# .env.docker.example — Docker 部署環境變數範本
#
# 使用方式:
#   1. 複製為 .env.docker (PowerShell): Copy-Item .env.docker.example .env.docker
#   2. 編輯 .env.docker,改密碼
#   3. docker compose up -d 會自動讀取 .env.docker
#
# 注意: .env.docker 在 .gitignore 中,不要 commit 進 git
# ============================================================

# ====== 資料庫設定 ======
# 預設值:cpuser / cppassword / container_packing
# 正式部署一定要改密碼 (預設值是公開知道的)
POSTGRES_USER=cpuser
POSTGRES_PASSWORD=請改成你的強密碼
POSTGRES_DB=container_packing

# ====== pgAdmin 登入設定 ======
# 開啟 http://localhost:5050 後用這組帳密登入
[email protected]
PGADMIN_PASSWORD=admin
